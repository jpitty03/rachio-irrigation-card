  },
  "dependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "custom-card-helpers": "^1.9.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.10"
  }
}
