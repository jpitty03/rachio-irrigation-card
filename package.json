{
  "name": "rachio-irrigation-card",
  "version": "1.0.3",
  "description": "A compact irrigation dashboard card for Home Assistant, designed for Rachio-style zone control.",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
