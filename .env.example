# Home Assistant SSH connection for local deploy
# Copy this file to .env and fill in your password:
#   cp .env.example .env

HA_HOST=homeassistant.local
HA_PORT=22
HA_USER=jpitty
HA_PASS=your-password-here

# Remote path where the JS file is served from
# This is the HACS community path — change if using a different location
HA_REMOTE_PATH=/root/homeassistant/www/community/rachio-irrigation-card/rachio-irrigation-card.js